# Server
PORT=3000
NODE_ENV=development

# Database (development uchun alohida)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=enavbat

# Yoki DATABASE_URL formatda (production uchun)
# DATABASE_URL=postgresql://user:pass@localhost:5432/enavbat

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-min-32-characters-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS - frontend URL
CORS_ORIGIN=http://localhost:3001

# SMS
SMS_API_KEY=your-sms-gateway-key
SMS_SENDER=E-NAVBAT
