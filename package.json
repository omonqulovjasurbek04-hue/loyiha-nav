{
  "name": "enavbat-uz",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"blue,green\" \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nest start --watch",
    "server:build": "nest build",
    "server:start": "node server/dist/main.js",
    "client:dev": "cd client && next dev",
    "client:build": "cd client && next build",
    "client:start": "cd client && next start",
    "build": "npm run server:build && npm run client:build",
    "start": "concurrently -n \"API,WEB\" -c \"blue,green\" \"npm run server:start\" \"npm run client:start\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "lint:server": "eslint \"server/src/**/*.ts\" --fix",
    "lint:client": "next lint --dir client",
    "test": "jest --config server/jest.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.18",
    "axios": "^1.14.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "next": "16.2.2",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
